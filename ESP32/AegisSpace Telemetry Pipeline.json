        "inputSchema": "{\"type\":\"object\",\"properties\":{\"is_anomaly\":{\"type\":\"boolean\"},\"severity\":{\"type\":\"string\",\"enum\":[\"normal\",\"warning\",\"critical\"]},\"anomaly_reason\":{\"type\":\"string\"},\"confidence\":{\"type\":\"number\"}},\"required\":[\"is_anomaly\",\"severity\",\"anomaly_reason\",\"confidence\"]}"
      },
      "id": "af6bdc62-e992-4d02-bd75-ebff23fc19e7",
      "name": "Structured Anomaly Output",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        1152,
        656
      ]
    },
    {
      "parameters": {
        "jsCode": "const v = $('Validate & Detect Anomaly').first().json;\nconst ai = $json;\nconst is_anomaly = ai.is_anomaly === true || String(ai.is_anomaly).toLowerCase() === 'true';\nconst severity = String(ai.severity || 'normal').toLowerCase();\nconst anomaly_reason = String(ai.anomaly_reason || 'No explanation provided');\nconst confidence = Number(ai.confidence || 0);\nconst ai_status = ai.ai_status || 'active';\nreturn [{ json: { device_id: v.device_id, temperature: v.temperature, voltage: v.voltage, current: v.current, gyro_x: v.gyro_x, gyro_y: v.gyro_y, gyro_z: v.gyro_z, is_anomaly, anomaly_reason, severity, confidence, ai_status } }];"
      },
      "id": "40dc85c7-e030-48d9-b1b0-3f232c64ed6a",
      "name": "Merge AI Analysis",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        112
      ]
    },
    {
      "parameters": {
        "jsCode": "const v = $('Validate & Detect Anomaly').first().json;\nconsole.warn('[AEGIS] Gemini unavailable for device=' + v.device_id);\nreturn [{ json: { is_anomaly: v.is_anomaly, severity: v.rule_severity ?? (v.is_anomaly ? 'warning' : 'normal'), anomaly_reason: v.anomaly_reason ?? 'Fallback: ' + v.anomaly_reason, confidence: 0.6, ai_status: 'fallback' } }];"
      },
