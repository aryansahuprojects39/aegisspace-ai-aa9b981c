    {
      "parameters": {
        "jsCode": "const d = $('Merge AI Analysis').first().json;\nconsole.warn('[AEGIS ANOMALY] ID: ' + d.device_id + ' | SEVERITY: ' + d.severity + ' | REASON: ' + d.anomaly_reason);\nreturn [{ json: { logged: true, device_id: d.device_id, severity: d.severity, reason: d.anomaly_reason } }];"
      },
