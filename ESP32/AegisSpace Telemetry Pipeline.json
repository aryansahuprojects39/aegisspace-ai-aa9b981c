{
  "name": "AegisSpace Telemetry Pipeline",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "aegis-telemetry",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "b33bd2be-e207-4f9d-b28f-eff902e3d067",
      "name": "ESP32 Telemetry Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        160,
        288
      ],
      "webhookId": "a52c27db-5965-4de7-ac64-1942a5f4fbff"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body ?? $input.first().json;\nconst device_id = String(body.device_id ?? 'esp32-001');\nconst temperature = parseFloat(body.temperature ?? 0);\nconst voltage = parseFloat(body.voltage ?? 0);\nconst current = parseFloat(body.current ?? 0);\nconst gyro_x = parseFloat(body.gyro_x ?? 0);\nconst gyro_y = parseFloat(body.gyro_y ?? 0);\nconst gyro_z = parseFloat(body.gyro_z ?? 0);\nif (!/^esp32-[a-zA-Z0-9\\-]+$/.test(device_id)) { throw new Error('Invalid device_id: ' + device_id); }\nif (isNaN(temperature) || isNaN(voltage) || isNaN(current)) { throw new Error('temperature / voltage / current must be numeric'); }\nconst reasons = [];\nif (temperature >= 85) reasons.push('CRITICAL temperature (' + temperature.toFixed(1) + 'C)');\nelse if (temperature >= 70) reasons.push('High temperature (' + temperature.toFixed(1) + 'C)');\nif (voltage < 3.0) reasons.push('Low voltage (' + voltage.toFixed(2) + 'V)');\nelse if (voltage > 5.5) reasons.push('Overvoltage (' + voltage.toFixed(2) + 'V)');\nif (current > 2.0) reasons.push('Overcurrent (' + current.toFixed(3) + 'A)');\nconst gyroMag = Math.sqrt(gyro_x**2 + gyro_y**2 + gyro_z**2);\nif (gyroMag > 250) reasons.push('High angular rate (' + gyroMag.toFixed(1) + ' deg/s)');\nconst deviceFlagged = body.is_anomaly === true || body.is_anomaly === 'true';\nconst is_anomaly = deviceFlagged || reasons.length > 0;\nconst anomaly_reason = is_anomaly ? (body.anomaly_reason || reasons.join('; ') || 'Flagged by device') : null;\nlet rule_severity = 'normal';\nif (temperature >= 85 || voltage < 3.0 || current > 2.0) rule_severity = 'critical';\nelse if (is_anomaly) rule_severity = 'warning';\nreturn [{ json: { device_id, temperature, voltage, current, gyro_x, gyro_y, gyro_z, is_anomaly, anomaly_reason, rule_severity } }];"
      },
      "id": "f9791479-07a9-41d8-a91a-4665e1a3b6d6",
      "name": "Validate & Detect Anomaly",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        384,
